<script>

 //let materialCategory = '<%# JSON.stringify(materialCategory) %>'
 //materialCategory=JSON.parse(materialCategory)
let tableDestination
let idDestination
// Draw Category Drop down
function drawCategoryDD(){
  let html=""
  materialCategory.forEach(el => {
    html+=`<option value="${el.id}">${el.category_name}</option>`
  });
   $('#categoryDD_Fld').html(html)
  
}
// Draw and update table
async function  drawTable (){
   await $.ajax({
        type: "GET",
        url: "/destination/getAll",
        success: async function (response) {
          console.log(response)
            let html=""
            for (let i = 0; i < response.Destinations.length; i++) {
                let el=response.Destinations[i]
                let delBtnDisable=""
                // if (el.used!=0){
                //   delBtnDisable="disabled"
                // }
                html+=`<tr>
                           <td>
                            <button type="button" name="" id="showBtn${el.id}" 
                            class="btn btn-primary btn-xs showDestination" style="width:25px"
                            idDestination="${el.id}" DestinationName="${el.Destination_name}">
                              <i class="fa fa-eye fa-sm" aria-hidden="true"></i>
                          </button>
                          <button type="button" name="" id="delete${el.id}" 
                          class="btn btn-danger btn-xs deleteDestination_Btn" style="width: 25px" 
                          idDestination="${el.id}" DestinationName="${el.Destination_name }" ${delBtnDisable}>
                            <i class="fa fa-trash fa-sm " aria-hidden="true"></i>
                          </button>
                        </td>
                                <td>${el.name} ${el.surname}</td>
                                <td>${el.address}</td>
                                <td></td>
                                <td>${moment(el.createdAt).format("DD-MM-YY HH:mm")}</td>
                            </tr>`
                
                }
                await $('#Destination_Tbl').DataTable().clear().rows.add($(html)).draw();
            }
    });

}

$(document).ready(async function () {
  // init
    
    tableDestination=$('#Destination_Tbl').DataTable({responsive: true,pageLength: 50});
    await drawTable()
    
    // Card
    // New rawMAterial
  $("#newDestination_Btn").click(async function (e) { 
    e.preventDefault();
    $("#Destination_Form").trigger("reset")   
    $(".DestinationForm").show()
    $(".DestinationText").hide()
    $("#rowDestination").hide() 
    $("#newDestination_Btn").hide()
    $("#backToMain_Btn").show()
    $("#tableDestination_Crd").hide()
    $("#showDestination_Crd").show()
    $("#element_Row").hide()
    $("#saveDestination_Btn").show()
  });
  // --> New destination
  $("#saveNewDestination_Btn").click(function (e) { 
    e.preventDefault();
    $("#cod_Destination_Fld").removeAttr("disabled")
    $.ajax({
        type: "POST",
        url: "/destination/newDestination",
        data: $("#Destination_Form").serialize(),   
        success: async function (response) {
          window.location="/destination"
        }
      });
   
    });
   // --> New destination
   $("#saveModDestination_Btn").click(function (e) { 
    e.preventDefault();
    $.ajax({
        type: "PUT",
        url: "/destination/updateDestination",
        data: $("#Destination_Form").serialize(),   
        success: async function (response) {
          await drawTable()
          $("#showDestination_Crd").hide()
          $("#tableDestination_Crd").show()
          $("#newDestination_Btn").show()
          $("#modDestination_Btn").hide()
          $("#backToMain_Btn").hide()
          $("#saveNewDestination_Btn").hide()
          $("#saveModDestination_Btn").hide()
          $("#saveDestination_Btn").show()
          $(".DestinationForm").hide()
          $(".DestinationText").show()
          $('#Destination_Form')[0].reset();
        }
      });
    });
  
    // Back to main
  $("#backToMain_Btn").click(async function (e) { 
    e.preventDefault();
    await drawTable()
    $("#newDestination_Btn").show()
    $("#backToMain_Btn").hide()
    $("#newDestination_Crd").hide()
    $("#showDestination_Crd").hide()
    $("#tableDestination_Crd").show()
    $("#modDestination_Btn").hide()
    $("#saveNewDestination_Btn").hide()
    $("#saveModDestination_Btn").hide()
  });  
  // Show/mod Raw material
  $(document).on("click",".showDestination", async function(e){
      $("#saveDestination_Btn").hide()

      let id=$(this).attr("idDestination")
      idDestination=id
      let DestinationName=$(this).attr("DestinationName")
      await $.ajax({
        type: "GET",
        url: "/destination/getOneDestination?id="+id,
        success: async function (response) {
          let data=response.destination
          // Populate GUI
          for (const [key, value] of Object.entries(data)) {
              if($("#"+key+"_Fld").attr("tp")=="textField"){
                $("#"+key+"_Fld").val(value)
              }
              if($("#"+key+"_Fld").attr("tp")=="selectField"){
                $("#"+key+"_Fld").val(value).change();
              }
                $("#"+key+"_Show").html(value?value:"-")
            }
            $("#id_Fld").val(data.id)
          if (response.destination.used>0){
              $("#saveDestination_Btn").hide()
              await drawTableDestination()
              $("#rowDestination").show()
              $("#addElement_Btn").prop("disabled","true")
              $(".delElement_Btn").prop("disabled","true")
            } else {
              $("#rowDestination").hide()
              $("#addElement_Btn").removeAttr("disabled")
              $(".delElement_Btn").removeAttr("disabled")
            }
          $("#showDestination_Crd").show()
          $("#tableDestination_Crd").hide()
          $("#newDestination_Btn").hide()
          $("#saveNewDestination_Btn").hide()
          $("#saveModDestination_Btn").show()
          $("#modDestination_Btn").show()
          $("#backToMain_Btn").show()
          $(".DestinationForm").hide()
          $(".DestinationText").show()
        }
      });   
    })
    $("#modDestination_Btn").click(function (e) { 
      e.preventDefault();
      $(".DestinationForm").show()
      $(".DestinationText").hide()
    }); 

    // Delete destination
    $(document).on("click",".deleteDestination_Btn", async function(e){
      e.preventDefault();
      let id=$(this).attr("idDestination")
      let c=confirm(`Stai eliminando una fornitore, vuoi continuare? `)
      if (c==true){
        $.ajax({
        type: "DELETE",
        url: "/destination/deleteDestination?id="+id,
        success: async function (response) {
          await drawTable()
        }
      });
      }
    })
});
    

</script>
